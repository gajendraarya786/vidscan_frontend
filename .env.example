# ─────────────────────────────────────────────────────────────────
# VidScan Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# On Vercel: Settings → Environment Variables
# On Railway: Variables tab in the service dashboard
#
# NEXT_PUBLIC_* vars are embedded in the client JS at build time.
# Do NOT put secrets (API keys, tokens) in NEXT_PUBLIC_ vars.
# ─────────────────────────────────────────────────────────────────

# FastAPI backend base URL (no trailing slash)
# Local:      http://localhost:8000
# Production: https://your-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical origin of this Next.js app — used for sitemap + OG tags
# Local:      http://localhost:3000
# Production: https://vidscan.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google AdSense publisher ID — leave blank to disable all ad slots
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=

# Ad unit slot IDs (from AdSense → Ad units dashboard)
NEXT_PUBLIC_AD_SLOT_TOP=
NEXT_PUBLIC_AD_SLOT_BOTTOM=
